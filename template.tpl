scenarios:
- name: ForCookie Basic Function Test
  code: |-
    // ====================================================================
    // TEST 1: Geçerli API Anahtarı ile Script Enjeksiyonu ve Rıza Durumu Kontrolü
    // ====================================================================

    // Test verisini hazırla (Kullanıcı GTM panelinde bu alanları doldurmuş gibi simüle edilir)
    const mockData = {
      apiKey: 'fc-test-123456',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      analytics_storage: 'granted', // Analitik çerezlerine onay verilmiş olsun
      functionality_storage: 'denied',
      personalization_storage: 'denied',
      security_storage: 'granted'
    };

    // GTM API'lerini (Mock) taklit et ve davranışlarını belirle
    mock('injectScript', function(url, onSuccess, onFailure) {
      // Kodun oluşturduğu URL'in doğruluğunu kontrol et
      assertThat(url).isEqualTo('https://api.forcookie.com/?apikey=fc-test-123456');
      // Başarılı yükleme senaryosunu tetikle
      onSuccess();
    });

    // Şablon kodunu bu verilerle çalıştır
    runCode(mockData);

    // updateConsentState API'sinin doğru parametrelerle çağrıldığını doğrula
    assertApi('updateConsentState').wasCalledWith({
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'analytics_storage': 'granted',
      'functionality_storage': 'denied',
      'personalization_storage': 'denied',
      'security_storage': 'granted'
    });


    // ====================================================================
    // TEST 2: Script Yükleme Hatası (Failure) Durumu Kontrolü
    // ====================================================================

    // İkinci test için GTM'in injectScript API'sini başarısız olacak şekilde yeniden ayarla
    mock('injectScript', function(url, onSuccess, onFailure) {
      // Script yüklenirken hata oluştuğunu simüle et
      onFailure();
    });

    // Şablonu tekrar çalıştır
    runCode(mockData);

    // injectScript başarısız olduğunda data.gtmOnFailure fonksiyonunun çağrıldığını doğrula
    // Not: runCode çalıştığında GTM arka planda başarı/başarısızlık callback'lerini otomatik yönetir.
