___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const queryPermission = require("queryPermission");
const injectScript = require("injectScript");
const updateConsentState = require("updateConsentState");

updateConsentState({
  'ad_storage': data.ad_storage || "denied",
  'ad_user_data': data.ad_user_data || "denied",
  'ad_personalization': data.ad_personalization || "denied",
  'analytics_storage': data.analytics_storage || "denied",
  'functionality_storage': data.functionality_storage || "denied",
  'personalization_storage': data.personalization_storage || "denied",
  'security_storage': data.security_storage || "granted"
});

// ForCookie script URL
const scriptURL = "https://api.forcookie.com/?apikey=" + data.apiKey;

if (!queryPermission("inject_script", scriptURL)) {
  data.gtmOnFailure();
} else {
  injectScript(scriptURL, data.gtmOnSuccess, data.gtmOnFailure);
}


